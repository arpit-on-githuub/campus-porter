PORT=3000
MONGO_URI=your_mongodb_atlas_connection_string
JWT_SECRET=your_random_secret_key

# --- Email (OTP delivery) ---
# Gmail works for local dev, but most free cloud hosts block outbound SMTP,
# which makes register/forgot-password hang. For deployment, use a transactional
# email provider (Brevo, SendGrid, Mailgun, Resend-SMTP, etc.) by setting
# EMAIL_HOST/EMAIL_PORT below. If EMAIL_HOST is unset, Gmail is used.
EMAIL_USER=your_smtp_username_or_gmail@gmail.com
EMAIL_PASS=your_smtp_password_or_gmail_app_password
# Optional provider overrides (recommended in production):
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_FROM=SLING <no-reply@yourdomain.com>
