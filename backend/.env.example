PORT=3000
MONGO_URI=your_mongodb_atlas_connection_string
JWT_SECRET=your_random_secret_key

# --- Email (OTP delivery) ---
# Production (recommended): send via Brevo's HTTPS API. Many hosts (Render
# free, etc.) block outbound SMTP ports, so the API is the reliable path.
# Get a key from Brevo > SMTP & API > API Keys, then set:
# BREVO_API_KEY=your_brevo_api_key
# EMAIL_FROM=SLING <your-verified-sender@example.com>
#
# Local development (SMTP): Gmail works on a laptop. If EMAIL_HOST is unset,
# Gmail is used with the credentials below. When BREVO_API_KEY is set it takes
# priority over SMTP, so email works even where SMTP ports are blocked.
EMAIL_USER=your_smtp_username_or_gmail@gmail.com
EMAIL_PASS=your_smtp_password_or_gmail_app_password
# Optional SMTP provider overrides:
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_FROM=SLING <no-reply@yourdomain.com>
